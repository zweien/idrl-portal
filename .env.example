# ===== Database =====
# SQLite datasource URL (Prisma). Relative path resolves from project root.
DATABASE_URL="file:prisma/db.sqlite"

# ===== Session =====
# Secret used to sign the iron-session auth cookie. Must be >= 32 characters.
# Generate one with: openssl rand -base64 32
# In production this MUST be set; in development a default is used if absent.
SESSION_SECRET=""

# ===== Authentik SSO (intranet) — consumed by auth slice #4 =====
# OIDC issuer base URL of your Authentik instance, e.g. https://auth.example.internal/application/o/<app-slug>
AUTHENTIK_ISSUER=""
AUTHENTIK_CLIENT_ID=""
AUTHENTIK_CLIENT_SECRET=""

# ===== DingTalk OAuth (internet) — consumed by auth slice #5 =====
# From the DingTalk Open Platform app console
DINGTALK_CLIENT_ID=""
DINGTALK_CLIENT_SECRET=""

# ===== DingTalk org sync (dept root for member/attendance sync) =====
# The dept_id whose tree (self + sub-departments) to sync members from.
DINGTALK_DEPT_ID="340351089"
# Process code for the "出差" (business-trip) approval template.
# Find it in DingTalk admin → 应用管理 → 审批 → 出差模板.
# Leave empty to skip trip detection (only attendance + leave synced).
DINGTALK_TRIP_PROCESS_CODE=""

# ===== Auth provider routing (optional) =====
# Comma-separated list of intranet CIDR ranges. Requests from these ranges are
# offered Authentik first; everything else gets DingTalk. Leave empty to show both.
INTRANET_CIDRS=""
