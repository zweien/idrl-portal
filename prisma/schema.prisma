generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Floor {
  id           String         @id
  name         String
  order        Int
  zones        Zone[]
  workstations Workstation[]
}

model Zone {
  id           String        @id
  name         String
  floorId      String
  floor        Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  color        String
  order        Int
  mode         String
  rows         Int
  cols         Int
  maxRows      Int
  maxCols      Int
  workstations Workstation[]
}

model Workstation {
  id             String   @id
  name           String
  zoneId         String
  zone           Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  floorId        String
  floor          Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  row            Int
  col            Int
  personId       String?
  person         Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  status         String
  nameCustomized Boolean  @default(false)

  // One person may occupy at most one workstation. SQLite treats multiple
  // NULL personId values as distinct, so unassigned workstations coexist.
  @@unique([personId], map: "workstation_person_uniq")
}

model Person {
  id                String              @id
  name              String
  role              String
  email             String?
  phone             String?
  dingUserId        String?
  status            String
  lastSeen          String?
  researchAreas     String?
  avatar            String?
  workstations      Workstation[]
  users             User[]
  attendanceRecords AttendanceRecord[]
}

// Daily attendance punch history (sourced from DingTalk, then finalized).
// One row per (person, date); upserted on each sync so re-pulls are idempotent.
// checkIn/checkOut are "HH:mm" in Asia/Shanghai; null when the punch is
// missing for that day. status is the day's final attendance result.
model AttendanceRecord {
  id        String  @id @default(cuid())
  personId  String
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  date      String  // "yyyy-MM-dd" Asia/Shanghai
  checkIn   String? // OnDuty punch "HH:mm"
  checkOut  String? // OffDuty punch "HH:mm"
  status    String  // present | leave | trip | absent

  @@unique([personId, date])
  @@index([date])
  @@index([personId])
}

model User {
  id          String    @id @default(cuid())
  provider    String // "authentik" | "dingtalk" | "local"
  externalId  String // SSO subject/userId; local username for provider="local"
  role        String // "admin" | "member"
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  disabledAt  DateTime? // non-null = banned (cannot log in / call APIs)

  @@unique([provider, externalId])
}

model NewsItem {
  id         String  @id
  title      String
  content    String
  summary    String?
  author     String?
  date       String
  tags       String?
  imageUrl   String?
  link       String?
  pinned     Boolean @default(false)
  status     String  @default("published") // "draft" | "published"
  publishAt  String? // ISO datetime; when set + status=draft, scheduler flips to published
  order      Int      @default(0) // manual order within the pinned group (unpinned sort by date desc)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Resource {
  id          String  @id
  name        String
  description String
  url         String?
  icon        String?
  status      String
  specs       String?
  accessLevel String
  order       Int     @default(0) // manual order within the resource's category (uncategorized = one group)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// Unified categories for News (kind="news") and Resources (kind="resource").
model Category {
  id        String    @id @default(cuid())
  name      String
  kind      String // "news" | "resource"
  order     Int       @default(0)
  news      NewsItem[]
  resources Resource[]

  @@unique([kind, name])
}

// API keys for machine-to-machine access (sync triggers, publishing, reads).
// Stored as a sha256 hash; the plaintext is shown once at creation time.
//
// Rate limiting is shared across instances via DB counters on each row
// (rlWindowStart + rlCount), incremented atomically so concurrent requests
// can't under-count. rateLimitPerMin is per-key (null = global default).
model ApiKey {
  id              String    @id @default(cuid())
  name            String
  keyHash         String    @unique
  prefix          String    // first chars of the plaintext, for UI recognition
  scopes          String    // JSON array: ["sync:attendance", ...]
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  revokedAt       DateTime? // non-null = revoked
  rateLimitPerMin Int?      // per-key limit; null = use RATE_LIMIT_DEFAULT
  rlWindowStart   DateTime? // start of the current 60s counting window
  rlCount         Int       @default(0) // requests consumed in the current window
}

// Key/value app settings (e.g. cron expressions, enable flags).
model Setting {
  key   String @id
  value String
}

// Audit log for background jobs (sync + scheduled publishing).
model SyncLog {
  id        String   @id @default(cuid())
  job       String // "sync-members" | "sync-attendance" | "publish-news"
  source    String // "cron" | "api" | "manual"
  status    String // "success" | "error"
  message   String?
  stats     String? // JSON
  createdAt DateTime @default(now())
}

// Audit log for admin write operations (who/when/what). Separate from SyncLog
// (which records system jobs). actorId references a User.id or ApiKey.id but
// has no FK — logs must survive the actor being deleted/revoked.
model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actorType   String   // "user" | "apikey"
  action      String   // e.g. "user.update", "news.delete", "backup.restore"
  targetType  String   // e.g. "user", "news", "backup"
  targetId    String?
  summary     String
  status      String   @default("success") // "success" | "error"
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
